{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathgraph.dev/schemas/igp24/recommendation.schema.json",
  "title": "RouteRecommendation",
  "type": "object",
  "required": [
    "recommendation_id", "parent_hash", "target_pair", "law",
    "expected_child_hash", "expected_probability", "evidence",
    "obstructions", "rationale", "trust_label"
  ],
  "properties": {
    "recommendation_id": {"type": "string"},
    "parent_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_pair": {"type": "array", "minItems": 2, "maxItems": 2},
    "law": {"type": "object"},
    "expected_child_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "expected_probability": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {"type": "object"},
    "obstructions": {"type": "array"},
    "rationale": {"type": "array", "items": {"type": "string"}},
    "trust_label": {"type": "string"}
  },
  "additionalProperties": false
}

